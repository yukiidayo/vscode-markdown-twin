{
  "name": "markdown-twin-view",
  "displayName": "Markdown Twin",
  "description": "Inline bilingual translation for Markdown preview",
  "version": "1.0.0",
  "publisher": "yukiidayo",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yukiidayo/vscode-markdown-twin.git"
  },
  "homepage": "https://github.com/yukiidayo/vscode-markdown-twin#readme",
  "bugs": {
    "url": "https://github.com/yukiidayo/vscode-markdown-twin/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "markdown-preview",
    "translation",
    "translate",
    "translator",
    "preview",
    "bilingual",
    "localization",
    "l10n",
    "documentation",
    "docs",
    "technical-writing",
    "readme",
    "google-translate",
    "deepl",
    "azure-translator",
    "papago"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "build": "npm run compile && npm run bundle",
    "bundle": "node esbuild.js",
    "compile": "tsc -p ./ --noEmit",
    "package": "vsce package",
    "release:check": "npm run compile && npm test -- --runInBand && npm run bundle && npm run package",
    "watch": "node esbuild.js --watch",
    "test": "jest"
  },
  "contributes": {
    "commands": [
      {
        "command": "markdownTwin.toggleTranslation",
        "title": "%markdownTwin.commands.toggleTranslation%",
        "icon": "$(globe)"
      },
      {
        "command": "markdownTwin.toggleTranslation.ja",
        "title": "%markdownTwin.commands.translateTo.ja%",
        "icon": {
          "light": "./media/flags/ja.svg",
          "dark": "./media/flags/ja.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.en",
        "title": "%markdownTwin.commands.translateTo.en%",
        "icon": {
          "light": "./media/flags/en.svg",
          "dark": "./media/flags/en.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.ko",
        "title": "%markdownTwin.commands.translateTo.ko%",
        "icon": {
          "light": "./media/flags/ko.svg",
          "dark": "./media/flags/ko.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.es",
        "title": "%markdownTwin.commands.translateTo.es%",
        "icon": {
          "light": "./media/flags/es.svg",
          "dark": "./media/flags/es.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.fr",
        "title": "%markdownTwin.commands.translateTo.fr%",
        "icon": {
          "light": "./media/flags/fr.svg",
          "dark": "./media/flags/fr.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.de",
        "title": "%markdownTwin.commands.translateTo.de%",
        "icon": {
          "light": "./media/flags/de.svg",
          "dark": "./media/flags/de.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.it",
        "title": "%markdownTwin.commands.translateTo.it%",
        "icon": {
          "light": "./media/flags/it.svg",
          "dark": "./media/flags/it.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.pt",
        "title": "%markdownTwin.commands.translateTo.pt%",
        "icon": {
          "light": "./media/flags/pt.svg",
          "dark": "./media/flags/pt.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.ru",
        "title": "%markdownTwin.commands.translateTo.ru%",
        "icon": {
          "light": "./media/flags/ru.svg",
          "dark": "./media/flags/ru.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.vi",
        "title": "%markdownTwin.commands.translateTo.vi%",
        "icon": {
          "light": "./media/flags/vi.svg",
          "dark": "./media/flags/vi.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.th",
        "title": "%markdownTwin.commands.translateTo.th%",
        "icon": {
          "light": "./media/flags/th.svg",
          "dark": "./media/flags/th.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.id",
        "title": "%markdownTwin.commands.translateTo.id%",
        "icon": {
          "light": "./media/flags/id.svg",
          "dark": "./media/flags/id.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.ar",
        "title": "%markdownTwin.commands.translateTo.ar%",
        "icon": {
          "light": "./media/flags/ar.svg",
          "dark": "./media/flags/ar.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.hi",
        "title": "%markdownTwin.commands.translateTo.hi%",
        "icon": {
          "light": "./media/flags/hi.svg",
          "dark": "./media/flags/hi.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.zh-Hans",
        "title": "%markdownTwin.commands.translateTo.zh-Hans%",
        "icon": {
          "light": "./media/flags/zh-Hans.svg",
          "dark": "./media/flags/zh-Hans.svg"
        }
      },
      {
        "command": "markdownTwin.toggleTranslation.zh-Hant",
        "title": "%markdownTwin.commands.translateTo.zh-Hant%",
        "icon": {
          "light": "./media/flags/zh-Hant.svg",
          "dark": "./media/flags/zh-Hant.svg"
        }
      },
      {
        "command": "markdownTwin.toggleBilingual",
        "title": "%markdownTwin.commands.toggleBilingual%",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "markdownTwin.selectProvider",
        "title": "%markdownTwin.commands.selectProvider%"
      },
      {
        "command": "markdownTwin.setApiKey",
        "title": "%markdownTwin.commands.setApiKey%"
      },
      {
        "command": "markdownTwin.configureAzureRegion",
        "title": "%markdownTwin.commands.configureAzureRegion%"
      },
      {
        "command": "markdownTwin.openSettings",
        "title": "%markdownTwin.commands.openSettings%"
      },
      {
        "command": "markdownTwin.copyTranslatedMarkdown",
        "title": "%markdownTwin.commands.copyTranslatedMarkdown%",
        "icon": "$(copy)"
      },
      {
        "command": "markdownTwin.exportTranslatedMarkdown",
        "title": "%markdownTwin.commands.exportTranslatedMarkdown%",
        "icon": "$(save)"
      },
      {
        "command": "markdownTwin.openTranslatedSource",
        "title": "%markdownTwin.commands.openTranslatedSource%",
        "icon": "$(code)"
      },
      {
        "command": "markdownTwin.openPreviewFromSource",
        "title": "%markdownTwin.commands.openPreviewFromSource%",
        "icon": "$(eye)"
      },
      {
        "command": "markdownTwin.copyFromPreviewContext",
        "title": "%markdownTwin.commands.copyFromPreviewContext%"
      },
      {
        "command": "markdownTwin.retranslateFromPreviewContext",
        "title": "%markdownTwin.commands.retranslateFromPreviewContext%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "markdownTwin.toggleTranslation.ja",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.en",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.ko",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.es",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.fr",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.de",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.it",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.pt",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.ru",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.vi",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.th",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.id",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.ar",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.hi",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.zh-Hans",
          "when": "false"
        },
        {
          "command": "markdownTwin.toggleTranslation.zh-Hant",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "markdownTwin.toggleTranslation",
          "when": "resourceLangId == markdown && !markdownTwin.targetLang",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.ja",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'ja'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.en",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'en'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.ko",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'ko'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.es",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'es'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.fr",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'fr'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.de",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'de'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.it",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'it'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.pt",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'pt'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.ru",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'ru'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.vi",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'vi'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.th",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'th'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.id",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'id'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.ar",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'ar'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.hi",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'hi'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.zh-Hans",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'zh-Hans'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.toggleTranslation.zh-Hant",
          "when": "resourceLangId == markdown && markdownTwin.targetLang == 'zh-Hant'",
          "group": "navigation@1"
        },
        {
          "command": "markdownTwin.copyTranslatedMarkdown",
          "when": "markdownTwin.previewActive && activeWebviewPanelId == 'markdownTwinPreview'",
          "group": "navigation@2"
        },
        {
          "command": "markdownTwin.exportTranslatedMarkdown",
          "when": "markdownTwin.previewActive && activeWebviewPanelId == 'markdownTwinPreview'",
          "group": "navigation@3"
        },
        {
          "command": "markdownTwin.openPreviewFromSource",
          "when": "markdownTwin.previewActive && activeWebviewPanelId == 'markdownTwinPreview'",
          "group": "navigation@4"
        },
        {
          "command": "markdownTwin.openTranslatedSource",
          "when": "markdownTwin.previewActive && activeWebviewPanelId == 'markdownTwinPreview' && !markdownTwin.showingSource",
          "group": "navigation@4"
        }
      ],
      "webview/context": [
        {
          "command": "markdownTwin.copyFromPreviewContext",
          "when": "webviewId == 'markdownTwinPreview'"
        },
        {
          "command": "markdownTwin.retranslateFromPreviewContext",
          "when": "webviewId == 'markdownTwinPreview'"
        }
      ]
    },
    "configuration": {
      "title": "%markdownTwin.configuration.title%",
      "properties": {
        "markdownTwin.provider": {
          "type": "string",
          "enum": [
            "google-cloud",
            "microsoft",
            "deepl",
            "papago"
          ],
          "default": "google-cloud",
          "description": "%markdownTwin.provider.description%",
          "order": 1,
          "enumItemLabels": [
            "Google Cloud",
            "Azure",
            "DeepL",
            "Papago"
          ]
        },
        "markdownTwin.azureRegion": {
          "type": "string",
          "default": "global",
          "markdownDescription": "%markdownTwin.azureRegion.markdownDescription%",
          "order": 2
        },
        "markdownTwin.sourceLanguage": {
          "type": "string",
          "enum": [
            "auto",
            "ja",
            "en",
            "ko",
            "zh-Hans",
            "zh-Hant",
            "es",
            "fr",
            "de",
            "it",
            "pt",
            "ru",
            "vi",
            "th",
            "id",
            "ar",
            "hi"
          ],
          "default": "auto",
          "description": "%markdownTwin.sourceLanguage.description%",
          "order": 3,
          "enumItemLabels": [
            "Auto",
            "Japanese (日本語)",
            "English (English)",
            "Korean (한국어)",
            "Simplified Chinese (简体中文)",
            "Traditional Chinese (繁體中文)",
            "Spanish (Español)",
            "French (Français)",
            "German (Deutsch)",
            "Italian (Italiano)",
            "Portuguese (Português)",
            "Russian (Русский)",
            "Vietnamese (Tiếng Việt)",
            "Thai (ไทย)",
            "Indonesian (Bahasa Indonesia)",
            "Arabic (العربية)",
            "Hindi (हिन्दी)"
          ]
        },
        "markdownTwin.targetLanguage": {
          "type": "string",
          "enum": [
            "ko",
            "zh-Hans",
            "zh-Hant",
            "en",
            "ja",
            "es",
            "fr",
            "de",
            "it",
            "pt",
            "ru",
            "vi",
            "th",
            "id",
            "ar",
            "hi"
          ],
          "default": "ko",
          "description": "%markdownTwin.targetLanguage.description%",
          "order": 4,
          "enumItemLabels": [
            "Korean (한국어)",
            "Simplified Chinese (简体中文)",
            "Traditional Chinese (繁體中文)",
            "English (English)",
            "Japanese (日本語)",
            "Spanish (Español)",
            "French (Français)",
            "German (Deutsch)",
            "Italian (Italiano)",
            "Portuguese (Português)",
            "Russian (Русский)",
            "Vietnamese (Tiếng Việt)",
            "Thai (ไทย)",
            "Indonesian (Bahasa Indonesia)",
            "Arabic (العربية)",
            "Hindi (हिन्दी)"
          ]
        },
        "markdownTwin.defaultMode": {
          "type": "string",
          "enum": [
            "Translation Only",
            "Bilingual"
          ],
          "default": "Translation Only",
          "description": "%markdownTwin.defaultMode.description%",
          "order": 5,
          "enumItemLabels": [
            "%markdownTwin.defaultMode.translationOnly%",
            "%markdownTwin.defaultMode.bilingual%"
          ]
        },
        "markdownTwin.batchSize": {
          "type": "number",
          "default": 10,
          "description": "%markdownTwin.batchSize.description%",
          "order": 6
        },
        "markdownTwin.debounceDelay": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 10,
          "description": "%markdownTwin.debounceDelay.description%",
          "order": 7
        }
      }
    }
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "markdown-it": "^14.0.0",
    "plist": "^3.1.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/markdown-it": "^14.0.0",
    "@types/node": "^18.15.0",
    "@types/plist": "^3.0.5",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0"
  }
}
