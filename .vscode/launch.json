{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "${defaultBuildTask}"
    },
    {
      "name": "Build",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm.cmd run build"
    },
    {
      "name": "Package VSIX",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm.cmd run package"
    }
  ]
}
